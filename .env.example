# ─── HTTP ─────────────────────────────────────────────────────────────────────
AI_AGENT_PORT=8901
# Shared secret between PHP (Laravel) and this service.
# Must match AI_AGENT_SECRET in Laravel .env.
AI_AGENT_SECRET=change_me_to_random_string

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codeclass
DB_USERNAME=root
DB_PASSWORD=secret

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
# Override to point at a proxy (e.g. Rust mediarise-robot-console):
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_AGENT_MODEL=gpt-4o

# ─── Redis queue ──────────────────────────────────────────────────────────────
# Set to false to disable queues and run agent synchronously (direct mode).
AI_AGENT_QUEUE=true
AI_AGENT_WORKERS=4

# Connection: either a single URL or separate fields.
REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ─── Write permissions ────────────────────────────────────────────────────────
# false = only admins with level >= AI_AGENT_SUPERROOT_LEVEL can write.
# true  = all admins can use write tools (create invoice, update user, etc.).
AI_AGENT_ALLOW_WRITE=false
AI_AGENT_SUPERROOT_LEVEL=100

# ─── ERP filesystem ───────────────────────────────────────────────────────────
# Absolute path to the Laravel project root.
# Used by read_file / list_files / grep_codebase tools.
ERP_ROOT=/var/www/codeclass
